build uf2: phony CMakeFiles/uf2


#############################################
# Utility command for uf2-app

build uf2-app: phony CMakeFiles/uf2-app


#############################################
# Utility command for __ldgen_output_sections.ld

build __ldgen_output_sections.ld: phony CMakeFiles/__ldgen_output_sections.ld esp-idf/esp_system/ld/sections.ld esp-idf/esp_event/libesp_event.a esp-idf/espressif__mqtt/libespressif__mqtt.a esp-idf/main/libmain.a esp-idf/tcp_transport/libtcp_transport.a esp-idf/xtensa/libxtensa.a


#############################################
